{
  "info": { "name": "rest", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "item": [
    {
      "name": "get json",
      "request": { "method": "GET", "url": "https://jsonplaceholder.typicode.com/users/1" },
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
          "pm.test('has id', function () { pm.expect(pm.response.json()).to.have.property('id'); });",
          "pm.test('has email', function () { pm.expect(pm.response.json()).to.have.property('email'); });"
        ] } }
      ]
    }
  ]
}
